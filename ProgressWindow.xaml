<Window x:Class="CommissioningChecklistGenerator.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommissioningChecklistGenerator"
        mc:Ignorable="d"
        Title="Checklist Generating..." Height="200" Width="300
        ">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageMain" Text="Please wait, the checklist is now generating..." TextAlignment="Center" VerticalAlignment="Center"/>
        <ProgressBar x:Name="CurrentProgress" Margin="10 0" Grid.Row="1" d:Value="50"/>
        <TextBlock x:Name="CurrentTask" Margin="10 5" d:Text="Current Task" Text="" Grid.Row="2"/>
    </Grid>
</Window>
