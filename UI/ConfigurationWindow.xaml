<Window x:Name="Configuration" x:Class="CommissioningChecklistGenerator.UI.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:data="clr-namespace:CommissioningChecklistGenerator"
        mc:Ignorable="d"
        Title="Configuration Editor" MinHeight="250" MinWidth="500" SizeToContent="WidthAndHeight">
    <Border Margin="5">
        <AdornerDecorator>
            <Grid x:Name="MainGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height=".25*"/>
                    <RowDefinition Height=".45*"/>
                    <RowDefinition Height=".25*"/>
                    <RowDefinition Height=".25*"/>
                    <RowDefinition Height=".5*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.ColumnSpan="2" Margin="5" VerticalAlignment="Center" Content="Server URL" FontSize="16" FontWeight="Bold"/>
                <TextBox ToolTip="the web server hosting your database" x:Name="ServerURL" Grid.Row="1" Grid.ColumnSpan="2" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" VerticalAlignment="Stretch" Margin="5" Style="{ StaticResource ValidatedTextBox }" Text="{ Binding URL, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True }"></TextBox>
                <Label Grid.Row="2" Grid.ColumnSpan="2" VerticalContentAlignment="Bottom" Content="Generated Database URL" FontWeight="Bold"></Label>
                <Label ToolTip="this will be the file the application will attempt to download if you save the configuration now" x:Name="ServerURLComplete" Grid.Row="3" Grid.ColumnSpan="2" VerticalContentAlignment="Center" FontStyle="Italic" Foreground="CadetBlue" d:Content="https://www.foobar/db/latest.db"></Label>
                <Button ToolTip="saves the configuration to disk" x:Name="SaveConfiguration" Grid.Row="6" Content="Save Configuration" Margin="5" Click="OnSaveConfigurationClick"></Button>
            </Grid>
        </AdornerDecorator>
    </Border>
</Window>
