<Window x:Class="CommissioningChecklistGenerator.UI.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommissioningChecklistGenerator"
        mc:Ignorable="d"
        d:Title="Generating..." MinHeight="200" MinWidth="300" MaxHeight="250" MaxWidth="350"
        Icon="pack://application:,,,/ui/icons/icon_color.ico"
        Style="{ StaticResource ProgressWindowStyle }">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition MaxHeight="20" Height="1*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" FontSize="18" TextWrapping="Wrap" x:Name="CurrentTask" Margin="5" TextAlignment="Center" VerticalAlignment="Center" d:Text="Current Task"/>
        <TextBlock Grid.Row="0" TextWrapping="Wrap" x:Name="MessageMain" TextAlignment="Center" VerticalAlignment="Center" d:Text="Please wait.." Margin="5"/>
        <ProgressBar x:Name="CurrentProgress" Margin="10 0" Grid.Row="2" d:Value="50"/>
    </Grid>
</Window>
