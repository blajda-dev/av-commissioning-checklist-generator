<Window x:Class="CommissioningChecklistGenerator.UI.AddEditItem"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:extension="clr-namespace:CommissioningChecklistGenerator.Extensions"
        xmlns:av="clr-namespace:CommissioningChecklistGenerator.ProjectModel"
        mc:Ignorable="d"
        Height="300" Width="600
        ">
    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <GroupBox x:Name="MediaTypeGroup" Header="Media Type">
            <Grid x:Name="MediaTypeGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 
                <RadioButton Checked="OnAudioVideoIsChecked" x:Name="AudioVideo" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0" Content="Audio/Video"/>
                <RadioButton Checked="OnAudioIsChecked" x:Name="Audio" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1" Content="Audio"/>
                <RadioButton Checked="OnVideoIsChecked" x:Name="Video" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="2" Content="Video"/>
                -->
            </Grid>
        </GroupBox>
        <GroupBox x:Name="ControlType" Grid.Column="1" Header="Control Type">
            <Grid x:Name="ControlTypeGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--
                <ComboBox ItemsSource="{Binding Source={extension:EnumerationExtension {x:Type av:ControlType}}}" SelectedItem="{Binding thisDevice.ControlMethod}" Margin="0, 2" x:Name="ControlTypeSelector" Grid.ColumnSpan="3"/>
                <TextBlock TextWrapping="Wrap" x:Name="ControlConnectorLabel" TextAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Text="Control Connector:"/>
                <TextBox Text="{Binding thisDevice.ControlMethodDescription}"  x:Name="ControlConnector" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                -->
            </Grid>
        </GroupBox>
        <GroupBox x:Name="Details" Grid.Row="1" Grid.ColumnSpan="2" Grid.RowSpan="2"  Header="Details">
            <Grid x:Name="DetailsGrid">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="NameLabel" TextAlignment="Center" VerticalAlignment="Center" Grid.Row="0" Text="Name:"/>
                <TextBox Text="{Binding thisDevice.Name}"  x:Name="ItemName" Margin="2" Grid.Column="1" Grid.ColumnSpan="2"/>
                <TextBlock x:Name="InputLabel"  TextAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Text="Input:"/>
                <TextBox Text="{Binding thisDevice.Input}" x:Name="Input" Margin="2" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                <TextBlock x:Name="OutputLabel" TextAlignment="Center" VerticalAlignment="Center" Grid.Row="2" Text="Output:"/>
                <TextBox Text="{Binding thisDevice.Output}" x:Name="Output" Margin="2" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"/>
            </Grid>
        </GroupBox>
        <!-- <Button x:Name="Complete" Grid.Row="3" Grid.Column="1" Margin="5" Content="Add/Edit Source" Click="OnAddEditCompleted"/> -->
    </Grid>
</Window>
